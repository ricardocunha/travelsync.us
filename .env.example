# Database
DB_HOST=127.0.0.1
DB_PORT=3336
DB_USER=root
DB_PASS=root
DB_NAME=trip

# Amadeus
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# AI provider
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Python agent layer
OPENAI_MODEL=gpt-4.1-mini
EXA_API_KEY=
FIRECRAWL_API_KEY=
EXA_NUM_RESULTS=6
MAX_SCRAPED_SOURCES=4
FIRECRAWL_TIMEOUT_MS=15000

# API <-> agents boundary
AGENTS_BASE_URL=http://127.0.0.1:8000

# Go API server
API_HOST=127.0.0.1
API_PORT=9081
API_READ_TIMEOUT_MS=5000
API_WRITE_TIMEOUT_MS=10000
WEB_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

# React frontend
VITE_API_BASE_URL=http://127.0.0.1:9081/api/v1
VITE_ORGANIZATION_ID=1
VITE_ENABLE_MOCK=false
